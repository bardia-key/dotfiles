{
  "$schema": "https://opencode.ai/config.json",
  "tui": {
    "scroll_speed": 5
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    }
  },
  "permission": {
    "edit": "ask",
    "bash": {
        "*": "ask",
        "git *": "allow",
        "ls *": "allow",
        "grep *": "allow",
        "find *": "allow",
        "head *": "allow",
        "tail *": "allow",
        "cd *": "allow",
        "make *": "allow",
        "cat *": "allow",
        "xargs *": "allow",
        "rg *": "allow",
        "rm *": "deny"
    }
  },
  "keybinds": {
    "messages_half_page_up": "ctrl+y",
    "messages_half_page_down": "ctrl+e"
  }
}
